set $laptop eDP-1
set $main DP-6
set $secondary DP-7
set $wallpapers ~/Pictures/config
#set $current_wallpaper $(find ~/Pictures/config/main -type f -exec basename {} \; | shuf -n 1)

bindswitch --reload --locked lid:on output $laptop disable
bindswitch --reload --locked lid:off output $laptop enable

output $main position 0 0 bg $wallpapers/main/ico_B.png fill
output $secondary position -1440 -640 transform 270 bg $wallpapers/secondary/ico_A.png fill

workspace 1 output $main
workspace 3 output $main
workspace 5 output $main
workspace 7 output $main
workspace 9 output $main
workspace 2 output $secondary
workspace 4 output $secondary
workspace 6 output $secondary
workspace 8 output $secondary
workspace 10 output $secondary
